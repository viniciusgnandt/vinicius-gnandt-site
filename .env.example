# Google Analytics 4 — Admin > Fluxos de dados > seu fluxo > ID de mensuração (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Ads — Ferramentas > Conversões > sua conta (AW-XXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads — rótulo da conversão específica (ex: clique no WhatsApp), formato "AbCdEfGhIj"
# Encontrado em Ferramentas > Conversões > [ação de conversão] > Configuração > Tag
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Google Search Console — método "Tag HTML" na verificação de propriedade,
# copie só o valor do atributo content da meta tag (sem <meta ...>)
GOOGLE_SITE_VERIFICATION=
